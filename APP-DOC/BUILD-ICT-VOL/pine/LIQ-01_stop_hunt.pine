// LIQ-01 — Stop Hunt Reversal
// Weight: 15%
// Logic: EQ high/low swept 1–3 ticks · wick closes back inside range · volume spike · RSI divergence
// Edge: Retail stops harvested → institutional reversal — highest probability entry in ICT framework

//@version=5
indicator("LIQ-01 · Stop Hunt Reversal", overlay=true)

// ── Inputs ────────────────────────────────────────────────────────────────────
eq_lookback   = input.int(20,    "EQ high/low lookback",    minval=5, maxval=100)
sweep_ticks   = input.int(3,     "Max sweep ticks",         minval=1, maxval=10)
vol_spike_m   = input.float(2.0, "Volume spike multiplier", minval=1.2, maxval=5.0, step=0.1)
rsi_period    = input.int(14,    "RSI period")
rsi_div_bars  = input.int(5,     "RSI divergence lookback", minval=3, maxval=20)

// ── EQ levels ─────────────────────────────────────────────────────────────────
eq_high = ta.highest(high, eq_lookback)[1]  // previous N-bar high
eq_low  = ta.lowest(low,   eq_lookback)[1]  // previous N-bar low

tick = syminfo.mintick
sweep_range = sweep_ticks * tick

// ── Sweep detection ───────────────────────────────────────────────────────────
// Bull reversal: low swept EQ low by ≤ sweep_ticks, then closed back above
swept_low  = low <= eq_low + sweep_range and low >= eq_low - sweep_range and close > eq_low
swept_high = high >= eq_high - sweep_range and high <= eq_high + sweep_range and close < eq_high

// ── Volume spike ──────────────────────────────────────────────────────────────
vol_avg   = ta.sma(volume, 20)
vol_spike = volume >= vol_avg * vol_spike_m

// ── RSI divergence ────────────────────────────────────────────────────────────
rsi = ta.rsi(close, rsi_period)

// Bullish div: price lower low, RSI higher low
price_lower_low  = low < ta.lowest(low,   rsi_div_bars)[1]
rsi_higher_low   = rsi > ta.lowest(rsi,   rsi_div_bars)[1]
bull_div         = price_lower_low and rsi_higher_low

// Bearish div: price higher high, RSI lower high
price_higher_high = high > ta.highest(high, rsi_div_bars)[1]
rsi_lower_high    = rsi < ta.highest(rsi,   rsi_div_bars)[1]
bear_div          = price_higher_high and rsi_lower_high

// ── Entry signals ─────────────────────────────────────────────────────────────
long_entry  = swept_low  and vol_spike and bull_div
short_entry = swept_high and vol_spike and bear_div

plotshape(long_entry,  "LIQ Long",  style=shape.arrowup,   location=location.belowbar, color=color.lime,   size=size.normal)
plotshape(short_entry, "LIQ Short", style=shape.arrowdown,  location=location.abovebar, color=color.fuchsia, size=size.normal)

// EQ levels
plot(eq_high, "EQ High", color=color.new(color.red,   50), style=plot.style_linebr, linewidth=1)
plot(eq_low,  "EQ Low",  color=color.new(color.green, 50), style=plot.style_linebr, linewidth=1)

// RSI panel
hline(50, "RSI 50", color=color.gray, linestyle=hline.style_dashed)

// ── Alerts ────────────────────────────────────────────────────────────────────
alertcondition(long_entry,  "LIQ-01 LONG",  "LIQ-01: Stop Hunt Long · {{ticker}} · {{close}}")
alertcondition(short_entry, "LIQ-01 SHORT", "LIQ-01: Stop Hunt Short · {{ticker}} · {{close}}")
