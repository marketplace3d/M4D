//@version=5
strategy(
    "SURGE BRK Retest — Backtest v1.0",
    overlay          = true,
    initial_capital  = 10000,
    default_qty_type = strategy.percent_of_equity,
    default_qty_value= 10,          // 10% per trade
    commission_type  = strategy.commission.percent,
    commission_value = 0.05,        // 0.05% taker (Binance futures)
    slippage         = 2,           // 2 ticks slippage
    calc_on_order_fills = false,
    process_orders_on_close = false,
    max_bars_back    = 500
)

// =============================================================================
// SURGE BRK RETEST — NATIVE TRADINGVIEW STRATEGY (Backtest Engine)
// Mirrors SURGE_BRK_Retest.pine logic exactly.
// Use on: crypto OHLC (BTCUSDT, ETHUSDT, SOLUSDT 1H/4H/Daily preferred)
// =============================================================================

// ─── INPUTS (mirrors indicator) ───────────────────────────────────────────────
grp_brk = "Structure Break"
swing_len      = input.int(10,    "Swing Length",              minval=3, maxval=50,   group=grp_brk)
min_break_pct  = input.float(0.1, "Min Break Body %",          minval=0.01, step=0.05, group=grp_brk)
require_clean  = input.bool(false,"Require Clean Break Only",                         group=grp_brk)
vol_confirm    = input.bool(true, "Volume Confirmation",                              group=grp_brk)
vol_mult       = input.float(1.2, "Vol Multiplier",            minval=1.0, step=0.1,  group=grp_brk)

grp_ret = "Retest"
retest_bars    = input.int(20,    "Max Bars to Retest",        minval=3, maxval=60,   group=grp_ret)
retest_tol_pct = input.float(0.15,"Retest Touch Tolerance %",  minval=0.01, step=0.05, group=grp_ret)
require_pattern= input.bool(true, "Require Candle Pattern",                           group=grp_ret)

grp_risk = "Risk"
risk_atr_len   = input.int(14,    "ATR Length",                minval=5, maxval=50,   group=grp_risk)
sl_atr_mult    = input.float(1.5, "SL ATR Multiplier",         minval=0.5, step=0.25, group=grp_risk)
tp1_rr         = input.float(2.0, "TP1 R:R",                   minval=1.0, step=0.5,  group=grp_risk)
tp2_rr         = input.float(4.0, "TP2 R:R",                   minval=1.5, step=0.5,  group=grp_risk)
tp1_pct        = input.int(60,    "TP1 Size % of Position",    minval=10, maxval=90,   group=grp_risk)
use_swing_sl   = input.bool(true,  "Anchor SL to Swing",                              group=grp_risk)
trail_sl       = input.bool(true,  "Trail SL to Breakeven at TP1",                   group=grp_risk)

grp_filt = "Filters"
min_rr         = input.float(1.5, "Min R:R",                   minval=1.0, step=0.25, group=grp_filt)
trend_filter   = input.bool(true,  "EMA 200 Trend Filter",                            group=grp_filt)
max_open_trades= input.int(2,     "Max Concurrent Positions",  minval=1, maxval=5,    group=grp_filt)

// ─── CORE CALCS ──────────────────────────────────────────────────────────────
atr     = ta.atr(risk_atr_len)
ema200  = ta.ema(close, 200)
vol_avg = ta.sma(volume, 20)
volOk   = not vol_confirm or volume > vol_avg * vol_mult
trendBull = not trend_filter or close > ema200
trendBear = not trend_filter or close < ema200

// ─── SWING DETECTION ─────────────────────────────────────────────────────────
ph = ta.pivothigh(high, swing_len, swing_len)
pl = ta.pivotlow(low,   swing_len, swing_len)

var float[] swingHighs  = array.new_float(0)
var int[]   swingHighBar = array.new_int(0)
var float[] swingLows   = array.new_float(0)
var int[]   swingLowBar  = array.new_int(0)

if not na(ph)
    array.unshift(swingHighs, ph)
    array.unshift(swingHighBar, bar_index - swing_len)
    if array.size(swingHighs) > 8
        array.pop(swingHighs)
        array.pop(swingHighBar)

if not na(pl)
    array.unshift(swingLows, pl)
    array.unshift(swingLowBar, bar_index - swing_len)
    if array.size(swingLows) > 8
        array.pop(swingLows)
        array.pop(swingLowBar)

prevSwingHigh = array.size(swingHighs) >= 2 ? array.get(swingHighs, 1) : na
prevSwingLow  = array.size(swingLows)  >= 2 ? array.get(swingLows,  1) : na

// ─── BREAK DETECTION ─────────────────────────────────────────────────────────
classifyBreak(level, isBull) =>
    bodyBreak = isBull ? (close - level) / level * 100 >= min_break_pct :
                         (level - close) / level * 100 >= min_break_pct
    wickBreak = isBull ? high > level : low < level
    bodyBreak ? 2 : wickBreak ? 1 : 0

bullBreakType = na(prevSwingHigh) ? 0 : classifyBreak(prevSwingHigh, true)
bearBreakType = na(prevSwingLow)  ? 0 : classifyBreak(prevSwingLow,  false)

bullBreak = (bullBreakType == 2 or (bullBreakType == 1 and not require_clean)) and volOk and trendBull
bearBreak = (bearBreakType == 2 or (bearBreakType == 1 and not require_clean)) and volOk and trendBear

// ─── CANDLE PATTERNS ─────────────────────────────────────────────────────────
bodySize   = math.abs(close - open)
totalRange = high - low
upperWick  = high - math.max(close, open)
lowerWick  = math.min(close, open) - low

bullEngulf  = close > open and open < close[1] and close > open[1] and bodySize > math.abs(close[1] - open[1]) * 0.8
bearEngulf  = close < open and open > close[1] and close < open[1] and bodySize > math.abs(close[1] - open[1]) * 0.8
pinBarBull  = lowerWick > bodySize * 2.0 and lowerWick > upperWick * 2.0 and totalRange > 0
pinBarBear  = upperWick > bodySize * 2.0 and upperWick > lowerWick * 2.0 and totalRange > 0
rejWickBull = lowerWick > totalRange * 0.55 and close > open
rejWickBear = upperWick > totalRange * 0.55 and close < open

bullPattern = bullEngulf or pinBarBull or rejWickBull
bearPattern = bearEngulf or pinBarBear or rejWickBear

// ─── BREAK STATE BUFFER ───────────────────────────────────────────────────────
type BreakState
    bool  isBull
    float level
    int   breakBar
    int   breakType
    bool  confirmed
    float sl
    float tp1
    float tp2

var BreakState[] breaks = array.new(BreakState, 0)

if bullBreak and not na(prevSwingHigh)
    array.unshift(breaks, BreakState.new(true,  prevSwingHigh, bar_index, bullBreakType, false, 0.0, 0.0, 0.0))
    if array.size(breaks) > 6
        array.pop(breaks)

if bearBreak and not na(prevSwingLow)
    array.unshift(breaks, BreakState.new(false, prevSwingLow,  bar_index, bearBreakType, false, 0.0, 0.0, 0.0))
    if array.size(breaks) > 6
        array.pop(breaks)

// ─── RETEST + ENTRY LOGIC ─────────────────────────────────────────────────────
tolMult        = retest_tol_pct / 100
openTradeCount = strategy.opentrades

retestBull = false
retestBear = false
var float entryRef = na
var float slRef    = na
var float tp1Ref   = na
var float tp2Ref   = na

if array.size(breaks) > 0 and openTradeCount < max_open_trades
    for i = 0 to array.size(breaks) - 1
        bs = array.get(breaks, i)
        if bs.confirmed or bar_index - bs.breakBar > retest_bars
            continue

        if bs.isBull
            levelTop     = bs.level * (1 + tolMult)
            levelBtm     = bs.level * (1 - tolMult)
            touchedLevel = low <= levelTop and high >= levelBtm
            closedAbove  = close > bs.level
            patOk        = not require_pattern or bullPattern

            if touchedLevel and closedAbove and patOk
                swingSlRef = array.size(swingLows) > 0 ? array.get(swingLows, 0) : close - atr * sl_atr_mult
                slPrice    = use_swing_sl ? math.min(swingSlRef, close - atr * sl_atr_mult) :
                                           close - atr * sl_atr_mult
                slDist     = close - slPrice
                calcRR     = slDist > 0 ? (atr * tp1_rr) / slDist : 0

                if calcRR >= min_rr and slDist > 0
                    bs.confirmed := true
                    bs.sl        := slPrice
                    bs.tp1       := close + slDist * tp1_rr
                    bs.tp2       := close + slDist * tp2_rr
                    entryRef     := close
                    slRef        := slPrice
                    tp1Ref       := close + slDist * tp1_rr
                    tp2Ref       := close + slDist * tp2_rr
                    retestBull   := true
                    break

        else
            levelTop     = bs.level * (1 + tolMult)
            levelBtm     = bs.level * (1 - tolMult)
            touchedLevel = high >= levelBtm and low <= levelTop
            closedBelow  = close < bs.level
            patOk        = not require_pattern or bearPattern

            if touchedLevel and closedBelow and patOk
                swingSlRef = array.size(swingHighs) > 0 ? array.get(swingHighs, 0) : close + atr * sl_atr_mult
                slPrice    = use_swing_sl ? math.max(swingSlRef, close + atr * sl_atr_mult) :
                                           close + atr * sl_atr_mult
                slDist     = slPrice - close
                calcRR     = slDist > 0 ? (atr * tp1_rr) / slDist : 0

                if calcRR >= min_rr and slDist > 0
                    bs.confirmed := true
                    bs.sl        := slPrice
                    bs.tp1       := close - slDist * tp1_rr
                    bs.tp2       := close - slDist * tp2_rr
                    entryRef     := close
                    slRef        := slPrice
                    tp1Ref       := close - slDist * tp1_rr
                    tp2Ref       := close - slDist * tp2_rr
                    retestBear   := true
                    break

// ─── STRATEGY ORDERS ─────────────────────────────────────────────────────────
tp2_pct = 100 - tp1_pct

if retestBull
    strategy.entry("BRK Long", strategy.long, comment="BRK▲")
    strategy.exit("BRK Long TP1", "BRK Long",
                  qty_percent=tp1_pct, limit=tp1Ref, stop=slRef,
                  comment="TP1▲")
    strategy.exit("BRK Long TP2", "BRK Long",
                  qty_percent=tp2_pct, limit=tp2Ref, stop=slRef,
                  comment="TP2▲")

if retestBear
    strategy.entry("BRK Short", strategy.short, comment="BRK▼")
    strategy.exit("BRK Short TP1", "BRK Short",
                  qty_percent=tp1_pct, limit=tp1Ref, stop=slRef,
                  comment="TP1▼")
    strategy.exit("BRK Short TP2", "BRK Short",
                  qty_percent=tp2_pct, limit=tp2Ref, stop=slRef,
                  comment="TP2▼")

// Trail to breakeven after TP1 fills (approximated: when price passes TP1)
if trail_sl and strategy.opentrades > 0
    for i = 0 to strategy.opentrades - 1
        entPx = strategy.opentrades.entry_price(i)
        isLong = strategy.opentrades.size(i) > 0
        if isLong and high >= tp1Ref and not na(tp1Ref)
            strategy.exit("BE Trail L", strategy.opentrades.id(i), stop=entPx, comment="BE")
        if not isLong and low <= tp1Ref and not na(tp1Ref)
            strategy.exit("BE Trail S", strategy.opentrades.id(i), stop=entPx, comment="BE")

// ─── VISUALS ─────────────────────────────────────────────────────────────────
plotshape(retestBull, "Long Entry",  style=shape.triangleup,
          location=location.belowbar, color=#00E676, size=size.small)
plotshape(retestBear, "Short Entry", style=shape.triangledown,
          location=location.abovebar, color=#FF1744, size=size.small)
plot(ema200, "EMA 200", color=color.new(color.white, 60), linewidth=1)

// ─── PERFORMANCE TABLE ────────────────────────────────────────────────────────
var table perf = table.new(position.bottom_right, 2, 8,
                            bgcolor=color.new(#0D0D0D, 10),
                            border_color=color.new(color.white, 80), border_width=1)

if barstate.islast
    totalTrades = strategy.closedtrades
    winTrades   = strategy.wintrades
    lossTrades  = strategy.losstrades
    winRate     = totalTrades > 0 ? winTrades / totalTrades * 100 : 0
    netPnl      = strategy.netprofit
    maxDD       = strategy.max_drawdown
    profFactor  = strategy.grossprofit > 0 and strategy.grossloss > 0 ?
                  strategy.grossprofit / math.abs(strategy.grossloss) : 0
    avgWin      = winTrades > 0 ? strategy.grossprofit / winTrades : 0
    avgLoss     = lossTrades > 0 ? math.abs(strategy.grossloss) / lossTrades : 0
    expVal      = totalTrades > 0 ? netPnl / totalTrades : 0

    cellC(c, r, txt, tc) => table.cell(perf, c, r, txt, text_color=tc, text_size=size.tiny)
    header(txt) => table.cell(perf, 0, 0, txt, text_color=color.white, bgcolor=#1565C0, text_size=size.small)

    header("SURGE BRK Backtest")
    table.cell(perf, 1, 0, syminfo.ticker + " " + timeframe.period,
               text_color=color.white, bgcolor=#1565C0, text_size=size.small)

    cellC(0, 1, "Trades",       color.gray)
    cellC(1, 1, str.tostring(totalTrades), color.white)

    cellC(0, 2, "Win Rate",     color.gray)
    wrCol = winRate >= 50 ? color.green : color.red
    cellC(1, 2, str.tostring(math.round(winRate)) + "%", wrCol)

    cellC(0, 3, "Net PnL",      color.gray)
    pnlCol = netPnl >= 0 ? color.green : color.red
    cellC(1, 3, str.tostring(math.round(netPnl)) + " " + syminfo.currency, pnlCol)

    cellC(0, 4, "Profit Factor",color.gray)
    pfCol = profFactor >= 1.5 ? color.green : profFactor >= 1.0 ? color.yellow : color.red
    cellC(1, 4, str.tostring(math.round(profFactor * 100) / 100), pfCol)

    cellC(0, 5, "Max DD",       color.gray)
    cellC(1, 5, str.tostring(math.round(maxDD)) + " " + syminfo.currency, color.red)

    cellC(0, 6, "Avg W/L",      color.gray)
    cellC(1, 6, str.tostring(math.round(avgWin)) + "/" + str.tostring(math.round(avgLoss)), color.white)

    cellC(0, 7, "Expectancy",   color.gray)
    expCol = expVal >= 0 ? color.green : color.red
    cellC(1, 7, str.tostring(math.round(expVal)) + " " + syminfo.currency, expCol)
