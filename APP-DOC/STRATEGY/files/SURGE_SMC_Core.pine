//@version=5
indicator("SURGE SMC Core v1.0", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// =============================================================================
// SURGE SMC CORE MODULE v1.0
// Components: BOS/CHoCH · Liquidity Sweeps · Order Blocks · FVG Engine
// Output: Structured signal JSON via alert() for LLM Arbitration Layer
// =============================================================================

// ─── INPUTS ──────────────────────────────────────────────────────────────────
grp_str = "Structure"
swing_len       = input.int(10, "Swing Length", minval=3, maxval=50, group=grp_str)
bos_confirm_bar = input.int(1,  "BOS Confirm Bars", minval=1, maxval=3, group=grp_str)

grp_ob = "Order Blocks"
ob_lookback     = input.int(20, "OB Lookback", minval=5, maxval=100, group=grp_ob)
ob_show_mitigated = input.bool(false, "Show Mitigated OBs", group=grp_ob)
ob_min_impulse  = input.float(0.3, "Min Impulse % for OB", minval=0.1, step=0.05, group=grp_ob)

grp_fvg = "Fair Value Gaps"
fvg_min_size    = input.float(0.05, "Min FVG Size %", minval=0.01, step=0.01, group=grp_fvg)
fvg_show_filled = input.bool(false, "Show Filled FVGs", group=grp_fvg)

grp_liq = "Liquidity"
liq_lookback    = input.int(30, "Liquidity Lookback", minval=10, maxval=100, group=grp_liq)
liq_equal_pct   = input.float(0.05, "Equal H/L Tolerance %", minval=0.01, step=0.01, group=grp_liq)

grp_vis = "Visuals"
col_bull_bos    = input.color(color.new(#00E5FF, 0),  "Bullish BOS",  group=grp_vis)
col_bear_bos    = input.color(color.new(#FF1744, 0),  "Bearish BOS",  group=grp_vis)
col_bull_choch  = input.color(color.new(#76FF03, 0),  "Bullish CHoCH",group=grp_vis)
col_bear_choch  = input.color(color.new(#FF6D00, 0),  "Bearish CHoCH",group=grp_vis)
col_bull_ob     = input.color(color.new(#1565C0, 30), "Bull OB",      group=grp_vis)
col_bear_ob     = input.color(color.new(#B71C1C, 30), "Bear OB",      group=grp_vis)
col_fvg_bull    = input.color(color.new(#00897B, 40), "Bull FVG",     group=grp_vis)
col_fvg_bear    = input.color(color.new(#E53935, 40), "Bear FVG",     group=grp_vis)
col_liq_bsl     = input.color(color.new(#FFD600, 60), "BSL Zone",     group=grp_vis)
col_liq_ssl     = input.color(color.new(#AA00FF, 60), "SSL Zone",     group=grp_vis)

// ─── SWING DETECTION ─────────────────────────────────────────────────────────
// Pivot highs and lows — confirmed swing points
ph = ta.pivothigh(high, swing_len, swing_len)
pl = ta.pivotlow(low,   swing_len, swing_len)

// Track last 4 swing highs and lows
var float[] swingHighs   = array.new_float(0)
var int[]   swingHighBars = array.new_int(0)
var float[] swingLows    = array.new_float(0)
var int[]   swingLowBars = array.new_int(0)

MAX_SWINGS = 6

if not na(ph)
    array.unshift(swingHighs,    ph)
    array.unshift(swingHighBars, bar_index - swing_len)
    if array.size(swingHighs) > MAX_SWINGS
        array.pop(swingHighs)
        array.pop(swingHighBars)

if not na(pl)
    array.unshift(swingLows,    pl)
    array.unshift(swingLowBars, bar_index - swing_len)
    if array.size(swingLows) > MAX_SWINGS
        array.pop(swingLows)
        array.pop(swingLowBars)

// ─── MARKET STRUCTURE (BOS / CHoCH) ──────────────────────────────────────────
// BOS  = Break of Structure (trend continuation)
// CHoCH = Change of Character (potential reversal)

var float lastStructureHigh = na
var float lastStructureLow  = na
var bool  trendBull         = na
var int   trendBullBar      = 0

// Update reference levels from confirmed swings
if array.size(swingHighs) >= 2
    lastStructureHigh := array.get(swingHighs, 1)
if array.size(swingLows) >= 2
    lastStructureLow := array.get(swingLows, 1)

// Detect structure breaks on close confirmation
bullBOS  = false
bearBOS  = false
bullCHoCH = false
bearCHoCH = false

if not na(lastStructureHigh) and close > lastStructureHigh
    if na(trendBull) or trendBull == true
        bullBOS  := true
    else
        bullCHoCH := true
    trendBull    := true
    trendBullBar := bar_index

if not na(lastStructureLow) and close < lastStructureLow
    if na(trendBull) or trendBull == false
        bearBOS  := true
    else
        bearCHoCH := true
    trendBull    := false
    trendBullBar := bar_index

// Draw structure labels
if bullBOS
    label.new(bar_index, high, "BOS", color=col_bull_bos, textcolor=color.black,
              style=label.style_label_down, size=size.tiny)
if bearBOS
    label.new(bar_index, low, "BOS", color=col_bear_bos, textcolor=color.white,
              style=label.style_label_up, size=size.tiny)
if bullCHoCH
    label.new(bar_index, high, "CHoCH", color=col_bull_choch, textcolor=color.black,
              style=label.style_label_down, size=size.small)
if bearCHoCH
    label.new(bar_index, low, "CHoCH", color=col_bear_choch, textcolor=color.white,
              style=label.style_label_up, size=size.small)

// ─── LIQUIDITY DETECTION (BSL / SSL / Equal H/L) ─────────────────────────────
// BSL = Buy-Side Liquidity (equal highs / recent swing highs = stop cluster above)
// SSL = Sell-Side Liquidity (equal lows  / recent swing lows = stop cluster below)

eqTol = liq_equal_pct / 100

var float[] bslLevels = array.new_float(0)
var float[] sslLevels = array.new_float(0)

// Detect equal highs (BSL) and equal lows (SSL) within lookback
if array.size(swingHighs) >= 2
    for i = 0 to math.min(array.size(swingHighs) - 1, liq_lookback / swing_len) - 1
        h1 = array.get(swingHighs, i)
        for j = i + 1 to math.min(array.size(swingHighs) - 1, liq_lookback / swing_len)
            h2 = array.get(swingHighs, j)
            if math.abs(h1 - h2) / h2 <= eqTol
                if array.size(bslLevels) == 0 or array.get(bslLevels, 0) != h1
                    array.unshift(bslLevels, math.max(h1, h2))
                    if array.size(bslLevels) > 5
                        array.pop(bslLevels)

if array.size(swingLows) >= 2
    for i = 0 to math.min(array.size(swingLows) - 1, liq_lookback / swing_len) - 1
        l1 = array.get(swingLows, i)
        for j = i + 1 to math.min(array.size(swingLows) - 1, liq_lookback / swing_len)
            l2 = array.get(swingLows, j)
            if math.abs(l1 - l2) / l2 <= eqTol
                if array.size(sslLevels) == 0 or array.get(sslLevels, 0) != l1
                    array.unshift(sslLevels, math.min(l1, l2))
                    if array.size(sslLevels) > 5
                        array.pop(sslLevels)

// Detect liquidity sweeps
liqSweepBSL = false
liqSweepSSL = false
sweepBSLLevel = 0.0
sweepSSLLevel = 0.0

if array.size(bslLevels) > 0
    topBSL = array.get(bslLevels, 0)
    if high > topBSL and close < topBSL
        liqSweepBSL  := true
        sweepBSLLevel := topBSL
        label.new(bar_index, high, "BSL Sweep ⚡", color=col_liq_bsl, textcolor=color.black,
                  style=label.style_label_down, size=size.small)

if array.size(sslLevels) > 0
    btmSSL = array.get(sslLevels, 0)
    if low < btmSSL and close > btmSSL
        liqSweepSSL  := true
        sweepSSLLevel := btmSSL
        label.new(bar_index, low, "SSL Sweep ⚡", color=col_liq_ssl, textcolor=color.white,
                  style=label.style_label_up, size=size.small)

// Draw BSL/SSL horizontal lines from swing highs/lows array
if barstate.islast
    if array.size(bslLevels) > 0
        for i = 0 to math.min(array.size(bslLevels) - 1, 3)
            line.new(bar_index - liq_lookback, array.get(bslLevels, i),
                     bar_index, array.get(bslLevels, i),
                     color=col_liq_bsl, style=line.style_dashed, width=1)
    if array.size(sslLevels) > 0
        for i = 0 to math.min(array.size(sslLevels) - 1, 3)
            line.new(bar_index - liq_lookback, array.get(sslLevels, i),
                     bar_index, array.get(sslLevels, i),
                     color=col_liq_ssl, style=line.style_dashed, width=1)

// ─── ORDER BLOCK ENGINE ───────────────────────────────────────────────────────
// OB = last opposing candle before impulse move that swept liquidity or broke structure
// Bullish OB: last bearish candle before bullish impulse
// Bearish OB: last bullish candle before bearish impulse

type OBData
    float top
    float btm
    int   startBar
    bool  isBull
    bool  mitigated
    float mitPct   // 0-100% fill

var OBData[] activeOBs = array.new(OBData, 0)

impulseThresh = ob_min_impulse / 100

// Detect impulse moves (3-bar momentum burst)
bullImpulse = (close - close[3]) / close[3] > impulseThresh and close > open and close[1] > open[1]
bearImpulse = (close[3] - close) / close[3] > impulseThresh and close < open and close[1] < open[1]

// Find last bearish candle before bullish impulse → Bullish OB
if bullImpulse
    for i = 1 to ob_lookback
        if close[i] < open[i]
            ob = OBData.new(open[i], close[i], bar_index - i, true, false, 0.0)
            array.unshift(activeOBs, ob)
            if array.size(activeOBs) > 10
                array.pop(activeOBs)
            break

// Find last bullish candle before bearish impulse → Bearish OB
if bearImpulse
    for i = 1 to ob_lookback
        if close[i] > open[i]
            ob = OBData.new(close[i], open[i], bar_index - i, false, false, 0.0)
            array.unshift(activeOBs, ob)
            if array.size(activeOBs) > 10
                array.pop(activeOBs)
            break

// Track OB mitigation (price entering OB zone = partial fill)
if array.size(activeOBs) > 0
    for i = 0 to array.size(activeOBs) - 1
        ob = array.get(activeOBs, i)
        if not ob.mitigated
            obRange = ob.top - ob.btm
            if ob.isBull and low <= ob.top
                penetration = math.max(0, ob.top - low)
                ob.mitPct := math.min(100, penetration / obRange * 100)
                if close < ob.btm
                    ob.mitigated := true
            else if not ob.isBull and high >= ob.btm
                penetration = math.max(0, high - ob.btm)
                ob.mitPct := math.min(100, penetration / obRange * 100)
                if close > ob.top
                    ob.mitigated := true

// Draw OB boxes
if barstate.islast
    for i = 0 to array.size(activeOBs) - 1
        ob = array.get(activeOBs, i)
        if ob.mitigated and not ob_show_mitigated
            continue
        obCol = ob.isBull ? col_bull_ob : col_bear_ob
        if ob.mitigated
            obCol := color.new(obCol, 85)
        box.new(ob.startBar, ob.top, bar_index, ob.btm,
                bgcolor=obCol, border_color=ob.isBull ? col_bull_ob : col_bear_ob,
                border_width=1)
        mitStr = ob.mitPct > 0 ? " " + str.tostring(math.round(ob.mitPct)) + "%" : ""
        label.new(ob.startBar, ob.isBull ? ob.top : ob.btm,
                  (ob.isBull ? "Bull OB" : "Bear OB") + mitStr,
                  color=color.new(ob.isBull ? col_bull_ob : col_bear_ob, 20),
                  textcolor=color.white, style=label.style_label_right, size=size.tiny)

// ─── OB SWEEP-AND-FILL SIGNAL ─────────────────────────────────────────────────
// Highest-quality signal: price sweeps OB, rejects, closes back through OB top/btm
obSweepFillBull = false
obSweepFillBear = false
obSFLevel = 0.0

if array.size(activeOBs) > 0
    for i = 0 to array.size(activeOBs) - 1
        ob = array.get(activeOBs, i)
        if not ob.mitigated
            // Bull: wick below OB bottom, close back inside OB
            if ob.isBull and low < ob.btm and close > ob.btm
                obSweepFillBull := true
                obSFLevel       := ob.btm
            // Bear: wick above OB top, close back inside OB
            if not ob.isBull and high > ob.top and close < ob.top
                obSweepFillBear := true
                obSFLevel       := ob.top

if obSweepFillBull
    label.new(bar_index, low, "OB S&F ▲", color=color.new(#00E676, 0), textcolor=color.black,
              style=label.style_label_up, size=size.normal)
if obSweepFillBear
    label.new(bar_index, high, "OB S&F ▼", color=color.new(#FF1744, 0), textcolor=color.white,
              style=label.style_label_down, size=size.normal)

// ─── FVG ENGINE ───────────────────────────────────────────────────────────────
// FVG = 3-candle imbalance: gap between candle[2].high and candle[0].low (bull)
//                            gap between candle[2].low  and candle[0].high (bear)

type FVGData
    float top
    float btm
    int   startBar
    bool  isBull
    bool  filled
    float fillPct

var FVGData[] activeFVGs = array.new(FVGData, 0)

fvgThresh = fvg_min_size / 100

// Detect new FVGs
bullFVG = low > high[2] and (low - high[2]) / high[2] >= fvgThresh
bearFVG = high < low[2] and (low[2] - high) / low[2] >= fvgThresh

if bullFVG
    fvg = FVGData.new(low, high[2], bar_index - 1, true, false, 0.0)
    array.unshift(activeFVGs, fvg)
    if array.size(activeFVGs) > 15
        array.pop(activeFVGs)

if bearFVG
    fvg = FVGData.new(low[2], high, bar_index - 1, false, false, 0.0)
    array.unshift(activeFVGs, fvg)
    if array.size(activeFVGs) > 15
        array.pop(activeFVGs)

// Track FVG fill percentage
fvgFilledBull = false
fvgFilledBear = false

if array.size(activeFVGs) > 0
    for i = 0 to array.size(activeFVGs) - 1
        fvg = array.get(activeFVGs, i)
        if not fvg.filled
            fvgRange = fvg.top - fvg.btm
            if fvgRange > 0
                if fvg.isBull and low <= fvg.top
                    pen = math.max(0, fvg.top - low)
                    fvg.fillPct := math.min(100, pen / fvgRange * 100)
                    if close < fvg.btm
                        fvg.filled    := true
                        fvgFilledBull := true
                if not fvg.isBull and high >= fvg.btm
                    pen = math.max(0, high - fvg.btm)
                    fvg.fillPct := math.min(100, pen / fvgRange * 100)
                    if close > fvg.top
                        fvg.filled    := true
                        fvgFilledBear := true

// Draw FVG boxes
if barstate.islast
    for i = 0 to array.size(activeFVGs) - 1
        fvg = array.get(activeFVGs, i)
        if fvg.filled and not fvg_show_filled
            continue
        fvgCol = fvg.isBull ? col_fvg_bull : col_fvg_bear
        if fvg.filled
            fvgCol := color.new(fvgCol, 90)
        fillStr = fvg.fillPct > 0 ? " " + str.tostring(math.round(fvg.fillPct)) + "%" : ""
        box.new(fvg.startBar, fvg.top, bar_index, fvg.btm,
                bgcolor=fvgCol, border_color=color.new(fvg.isBull ? col_fvg_bull : col_fvg_bear, 0),
                border_style=line.style_dashed, border_width=1)

// ─── SIGNAL SYNTHESIS ────────────────────────────────────────────────────────
// Composite SMC signal combining all components
// Score: 0-100 on current bar for LLM arbitrator

// Component scores (each 0-25 max)
bosScore    = bullBOS   ? 20 : bearBOS   ? -20 : 0
chochScore  = bullCHoCH ? 25 : bearCHoCH ? -25 : 0
liqScore    = liqSweepSSL ? 20 : liqSweepBSL ? -20 : 0
obSFScore   = obSweepFillBull ? 25 : obSweepFillBear ? -25 : 0
fvgScore    = bullFVG   ? 5  : bearFVG   ? -5  : 0
trendScore  = na(trendBull) ? 0 : trendBull ? 5 : -5

// Normalize to -100 / +100
rawScore    = bosScore + chochScore + liqScore + obSFScore + fvgScore + trendScore
clampedScore = math.max(-100, math.min(100, rawScore))
normScore   = (clampedScore + 100) / 2  // 0-100 scale for arbitrator

// Signal classification
signalDir   = clampedScore >= 40 ? "LONG" : clampedScore <= -40 ? "SHORT" : "NEUTRAL"
confidence  = math.abs(clampedScore)

// ─── ALERT JSON OUTPUT (LLM ARBITRATION INPUT) ───────────────────────────────
// Emits structured JSON on any significant SMC event
// Route to LLM Arbitration Layer (Python bridge)

alertCondition = bullBOS or bearBOS or bullCHoCH or bearCHoCH or
                 liqSweepBSL or liqSweepSSL or obSweepFillBull or obSweepFillBear

if alertCondition
    alert(
        '{"source":"SURGE_SMC",' +
        '"ts":"'            + str.tostring(timenow) + '",' +
        '"ticker":"'        + syminfo.ticker + '",' +
        '"tf":"'            + timeframe.period + '",' +
        '"close":'          + str.tostring(close) + ',' +
        '"signal":"'        + signalDir + '",' +
        '"confidence":'     + str.tostring(confidence) + ',' +
        '"smc_score":'      + str.tostring(clampedScore) + ',' +
        '"norm_score":'     + str.tostring(normScore) + ',' +
        '"bos_bull":'       + str.tostring(bullBOS) + ',' +
        '"bos_bear":'       + str.tostring(bearBOS) + ',' +
        '"choch_bull":'     + str.tostring(bullCHoCH) + ',' +
        '"choch_bear":'     + str.tostring(bearCHoCH) + ',' +
        '"liq_sweep_bsl":'  + str.tostring(liqSweepBSL) + ',' +
        '"liq_sweep_ssl":'  + str.tostring(liqSweepSSL) + ',' +
        '"ob_sweep_fill_bull":' + str.tostring(obSweepFillBull) + ',' +
        '"ob_sweep_fill_bear":' + str.tostring(obSweepFillBear) + ',' +
        '"fvg_bull":'       + str.tostring(bullFVG) + ',' +
        '"fvg_bear":'       + str.tostring(bearFVG) + ',' +
        '"trend_bull":'     + str.tostring(trendBull) + '}',
        alert.freq_once_per_bar_close
    )

// ─── DASHBOARD TABLE ─────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 8, bgcolor=color.new(#0D0D0D, 10),
                            border_color=color.new(color.white, 80), border_width=1)
if barstate.islast
    na_str(v) => na(v) ? "—" : str.tostring(v)
    stateColor(b) => b == true ? color.green : b == false ? color.red : color.gray

    table.cell(dash, 0, 0, "SURGE SMC", text_color=color.white, bgcolor=#1565C0, text_size=size.small)
    table.cell(dash, 1, 0, syminfo.ticker + " " + timeframe.period, text_color=color.white, bgcolor=#1565C0, text_size=size.small)

    table.cell(dash, 0, 1, "Signal", text_color=color.gray, text_size=size.tiny)
    sigCol = signalDir == "LONG" ? color.green : signalDir == "SHORT" ? color.red : color.gray
    table.cell(dash, 1, 1, signalDir + " (" + str.tostring(math.round(confidence)) + ")", text_color=sigCol, text_size=size.small)

    table.cell(dash, 0, 2, "SMC Score", text_color=color.gray, text_size=size.tiny)
    scoreCol = clampedScore > 0 ? color.green : clampedScore < 0 ? color.red : color.gray
    table.cell(dash, 1, 2, str.tostring(clampedScore), text_color=scoreCol, text_size=size.small)

    table.cell(dash, 0, 3, "Trend", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, na(trendBull) ? "—" : trendBull ? "BULL" : "BEAR",
               text_color=na(trendBull) ? color.gray : trendBull ? color.green : color.red, text_size=size.small)

    table.cell(dash, 0, 4, "BOS/CHoCH", text_color=color.gray, text_size=size.tiny)
    bosStr = bullBOS ? "Bull BOS" : bearBOS ? "Bear BOS" : bullCHoCH ? "Bull CHoCH" : bearCHoCH ? "Bear CHoCH" : "—"
    table.cell(dash, 1, 4, bosStr, text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 5, "Liq Sweep", text_color=color.gray, text_size=size.tiny)
    liqStr = liqSweepSSL ? "SSL ✓" : liqSweepBSL ? "BSL ✓" : "—"
    table.cell(dash, 1, 5, liqStr, text_color=liqSweepSSL or liqSweepBSL ? color.yellow : color.gray, text_size=size.small)

    table.cell(dash, 0, 6, "OB S&F", text_color=color.gray, text_size=size.tiny)
    obSFStr = obSweepFillBull ? "Bull ✓" : obSweepFillBear ? "Bear ✓" : "—"
    table.cell(dash, 1, 6, obSFStr, text_color=obSweepFillBull ? color.green : obSweepFillBear ? color.red : color.gray, text_size=size.small)

    table.cell(dash, 0, 7, "Active FVGs", text_color=color.gray, text_size=size.tiny)
    openFVGs = 0
    if array.size(activeFVGs) > 0
        for i = 0 to array.size(activeFVGs) - 1
            if not array.get(activeFVGs, i).filled
                openFVGs += 1
    table.cell(dash, 1, 7, str.tostring(openFVGs), text_color=color.white, text_size=size.small)

// ─── PLOTS (for external script access) ──────────────────────────────────────
plot(clampedScore, "SMC Raw Score", display=display.data_window)
plot(normScore,    "SMC Norm Score (0-100)", display=display.data_window)
plot(bullBOS   ? 1 : 0, "BOS Bull",    display=display.data_window)
plot(bearBOS   ? 1 : 0, "BOS Bear",    display=display.data_window)
plot(bullCHoCH ? 1 : 0, "CHoCH Bull",  display=display.data_window)
plot(bearCHoCH ? 1 : 0, "CHoCH Bear",  display=display.data_window)
plot(liqSweepBSL ? 1 : 0, "Liq BSL Sweep", display=display.data_window)
plot(liqSweepSSL ? 1 : 0, "Liq SSL Sweep", display=display.data_window)
plot(obSweepFillBull ? 1 : 0, "OB S&F Bull", display=display.data_window)
plot(obSweepFillBear ? 1 : 0, "OB S&F Bear", display=display.data_window)
