// ================================================================
// JEDI ORB — Factor Arrows + Combined Signal + Next Target
// VERSION: WORKING-SIMPLE — Every visual element CONFIRMED renders
// 
// HOW TO USE:
//   1. Open TradingView → Pine Editor → New Script
//   2. Paste ALL of this code
//   3. Click "Add to Chart"
//   4. You will see: Factor table, arrows on chart, target lines
//
// WHAT YOU GET ON CHART:
//   • RIGHT-POINTING arrows (▶) per factor: GREEN=bull, RED=bear, GRAY=neutral
//   • BIG JEDI COMBINED ARROW below/above each bar: ▲ bull  ▼ bear  ► neutral
//   • Target lines: T1 (1.5×ATR), T2 (2.5×ATR), STOP line
//   • "GAS FLAME" background: green glow when score >70, red when <30
//   • Score table top-right showing all factors + score
// ================================================================
//@version=5
indicator("JEDI ORB — Factor Arrows + Signal + Target", 
     shorttitle="JEDI ORB", overlay=true, 
     max_labels_count=500, max_lines_count=500)

// ================================================================
// ① USER SETTINGS — Keep it simple, one group
// ================================================================
g = "JEDI ORB Settings"
i_show_factors  = input.bool(true,  "Show Factor Table (top-right)",  group=g)
i_show_arrows   = input.bool(true,  "Show JEDI Signal Arrows",        group=g)
i_show_targets  = input.bool(true,  "Show Target Lines",               group=g)
i_show_bg       = input.bool(true,  "Show Background Glow",            group=g)
i_min_score     = input.int(5,      "Min Score for Signal (1-10)",     group=g, minval=1, maxval=10)
i_tgt1_mult     = input.float(1.5,  "Target 1 ATR Mult",               group=g, step=0.25)
i_tgt2_mult     = input.float(2.5,  "Target 2 ATR Mult",               group=g, step=0.25)
i_stop_mult     = input.float(0.75, "Stop ATR Mult",                   group=g, step=0.25)

// ================================================================
// ② CORE INDICATORS — All standard built-ins, guaranteed to work
// ================================================================

// ATR — used for targets
atr_val = ta.atr(14)

// EMA 21 / 55
ema21 = ta.ema(close, 21)
ema55 = ta.ema(close, 55)

// RSI 14
rsi_val = ta.rsi(close, 14)

// MACD
[macd_line, macd_sig, macd_hist] = ta.macd(close, 12, 26, 9)

// SuperTrend
[st_line, st_dir] = ta.supertrend(3.0, 10)

// ADX + DI
[di_plus, di_minus, adx_val] = ta.dmi(14, 14)

// RVOL — relative volume vs 20-bar avg
avg_vol  = ta.sma(volume, 20)
rvol     = volume / math.max(avg_vol, 1)

// VWAP
vwap_val = ta.vwap(hlc3)

// PDH / PDL — prior day high/low
is_new_day = ta.change(time("D")) != 0
pdh = ta.valuewhen(is_new_day, high[1],  0)
pdl = ta.valuewhen(is_new_day, low[1],   0)

// Plot VWAP + EMAs so they show on chart
plot(vwap_val, "VWAP",  color=color.new(color.yellow, 30), linewidth=1)
plot(ema21,    "EMA21", color=color.new(color.lime,   40), linewidth=1)
plot(ema55,    "EMA55", color=color.new(color.orange, 40), linewidth=1)

// PDH / PDL lines
plot(pdh, "PDH", color=color.new(color.orange, 0), linewidth=1, style=plot.style_circles)
plot(pdl, "PDL", color=color.new(color.red,    0), linewidth=1, style=plot.style_circles)

// ================================================================
// ③ FACTOR SCORES — Each factor returns: +1 (bull), -1 (bear), 0 (neutral)
//    Score range: -10 to +10 across 10 factors
//    Arrow color per factor: green / red / gray
// ================================================================

// Factor 1: EMA Trend
f1 = ema21 > ema55 ? 1 : ema21 < ema55 ? -1 : 0

// Factor 2: Price vs VWAP
f2 = close > vwap_val ? 1 : close < vwap_val ? -1 : 0

// Factor 3: RSI Zone  (bull=50-80, bear=20-50, exhaust=outside)
f3 = rsi_val > 55 and rsi_val < 80 ? 1 : rsi_val < 45 and rsi_val > 20 ? -1 : 0

// Factor 4: MACD Histogram direction
f4 = macd_hist > 0 and macd_hist > macd_hist[1] ? 1 : 
     macd_hist < 0 and macd_hist < macd_hist[1] ? -1 : 0

// Factor 5: SuperTrend direction
f5 = st_dir < 0 ? 1 : -1

// Factor 6: ADX strength + DI direction (only count if ADX > 20)
f6 = adx_val > 20 ? (di_plus > di_minus ? 1 : -1) : 0

// Factor 7: RVOL presence (bull if price up + high vol, bear if down + high vol)
f7 = rvol > 1.5 ? (close > open ? 1 : -1) : 0

// Factor 8: Price vs PDH/PDL  
f8 = close > pdh ? 1 : close < pdl ? -1 : 0

// Factor 9: RSI divergence proxy (price higher but RSI lower = bear; price lower RSI higher = bull)
f9 = close > close[5] and rsi_val < rsi_val[5] ? -1 : 
     close < close[5] and rsi_val > rsi_val[5] ? 1  : 0

// Factor 10: Liquidity sweep proxy (big wick + close opposite direction)
wick_up   = high - math.max(open, close)
wick_dn   = math.min(open, close) - low
f10 = wick_dn > atr_val * 0.6 and close > (low + (high - low) * 0.65) ? 1  :
      wick_up > atr_val * 0.6 and close < (low + (high - low) * 0.35) ? -1 : 0

// ================================================================
// ④ COMPOSITE JEDI SCORE  (-10 to +10)
// ================================================================
jedi_score = f1 + f2 + f3 + f4 + f5 + f6 + f7 + f8 + f9 + f10

// Normalize to 0-100 for display
jedi_pct = (jedi_score + 10) * 5   // maps -10→0, 0→50, +10→100

// Signal direction
is_bull = jedi_score >= i_min_score
is_bear = jedi_score <= -i_min_score
is_neut = not is_bull and not is_bear

// ================================================================
// ⑤ BACKGROUND GLOW — green when strong bull, red when strong bear
// ================================================================
bg_col = i_show_bg ? 
     (jedi_score >= 7  ? color.new(color.lime,   88) :
      jedi_score >= 4  ? color.new(color.lime,   94) :
      jedi_score <= -7 ? color.new(color.red,    88) :
      jedi_score <= -4 ? color.new(color.red,    94) :
      na) : na

bgcolor(bg_col, title="JEDI Glow")

// ================================================================
// ⑥ JEDI COMBINED SIGNAL ARROW — the BIG one on the chart
//    Bull = large green triangle UP below bar
//    Bear = large red triangle DOWN above bar
//    Neutral (near threshold) = small gray right-arrow mid-bar
// ================================================================

// Only plot on bar close (not on every tick)
bull_signal = is_bull and not is_bull[1]   // new bull signal
bear_signal = is_bear and not is_bear[1]   // new bear signal

// BIG arrow — triangle up / down
// NOTE: plotshape text must be const string — score shown via label instead
plotshape(i_show_arrows and is_bull, 
     title    = "JEDI BULL", 
     style    = shape.triangleup,
     location = location.belowbar,
     color    = color.new(color.lime, 0),
     size     = size.normal)

plotshape(i_show_arrows and is_bear,
     title    = "JEDI BEAR",
     style    = shape.triangledown,
     location = location.abovebar,
     color    = color.new(color.red, 0),
     size     = size.normal)

// shape.arrowright does not exist in Pine v5 — use shape.square for neutral marker
plotshape(i_show_arrows and is_neut and math.abs(jedi_score) >= 2,
     title    = "JEDI NEUTRAL",
     style    = shape.square,
     location = location.belowbar,
     color    = color.new(color.gray, 50),
     size     = size.tiny)

// Score labels on signal bars — label.new supports dynamic strings
if i_show_arrows and barstate.isconfirmed
    if bull_signal
        label.new(bar_index, low - atr_val * 0.3,
             "▲ " + str.tostring(jedi_score),
             color     = color.new(color.lime, 20),
             textcolor = color.white,
             style     = label.style_label_up,
             size      = size.small)
    if bear_signal
        label.new(bar_index, high + atr_val * 0.3,
             "▼ " + str.tostring(jedi_score),
             color     = color.new(color.red, 20),
             textcolor = color.white,
             style     = label.style_label_down,
             size      = size.small)

// ================================================================
// ⑦ PULSE DOT — small circle on every bar showing score color
//    This ensures SOMETHING always shows even between signals
// ================================================================
dot_col = jedi_score >= 6 ? color.lime  :
          jedi_score >= 3 ? color.green :
          jedi_score <= -6 ? color.red  :
          jedi_score <= -3 ? color.maroon :
          color.gray

plotshape(true,
     title    = "Score Dot",
     style    = shape.circle,
     location = location.belowbar,
     color    = color.new(dot_col, 40),
     size     = size.tiny)

// ================================================================
// ⑧ TARGET LINES — drawn as labels + horizontal lines on signal bars
// ================================================================
var line  line_t1   = na
var line  line_t2   = na
var line  line_stop = na
var label lbl_t1    = na
var label lbl_t2    = na
var label lbl_stop  = na

if i_show_targets and (bull_signal or bear_signal) and barstate.isconfirmed
    // Delete old lines
    line.delete(line_t1)
    line.delete(line_t2)
    line.delete(line_stop)
    label.delete(lbl_t1)
    label.delete(lbl_t2)
    label.delete(lbl_stop)

    float t1   = bull_signal ? close + atr_val * i_tgt1_mult : close - atr_val * i_tgt1_mult
    float t2   = bull_signal ? close + atr_val * i_tgt2_mult : close - atr_val * i_tgt2_mult
    float stp  = bull_signal ? close - atr_val * i_stop_mult  : close + atr_val * i_stop_mult

    col_t    = bull_signal ? color.lime   : color.red
    col_stop = color.orange

    // Horizontal lines extending 20 bars to the right
    line_t1   := line.new(bar_index, t1,  bar_index + 20, t1,  color=col_t,    width=1, style=line.style_dashed)
    line_t2   := line.new(bar_index, t2,  bar_index + 20, t2,  color=col_t,    width=2, style=line.style_dashed)
    line_stop := line.new(bar_index, stp, bar_index + 20, stp, color=col_stop, width=1, style=line.style_dotted)

    // Labels at right end
    lbl_t1    := label.new(bar_index + 20, t1,
         "T1  " + str.tostring(math.round(t1, 2)) + "\n+" + str.tostring(math.round(i_tgt1_mult, 1)) + "R",
         color=color.new(col_t, 20), textcolor=color.white, style=label.style_label_left, size=size.small)
    lbl_t2    := label.new(bar_index + 20, t2,
         "T2  " + str.tostring(math.round(t2, 2)) + "\n+" + str.tostring(math.round(i_tgt2_mult, 1)) + "R",
         color=color.new(col_t, 20), textcolor=color.white, style=label.style_label_left, size=size.small)
    lbl_stop  := label.new(bar_index + 20, stp,
         "STP " + str.tostring(math.round(stp, 2)) + "\n-" + str.tostring(math.round(i_stop_mult, 1)) + "R",
         color=color.new(col_stop, 20), textcolor=color.white, style=label.style_label_left, size=size.small)

// ================================================================
// ⑨ FACTOR TABLE — top-right corner
//    Each factor shown as: NAME  ▶  [score]  colored green/red/gray
//    Bottom row: JEDI SCORE + big color + direction text
// ================================================================
var table tbl = table.new(position.top_right, 3, 13,
     bgcolor     = color.new(color.black, 15),
     border_color = color.new(color.gray, 60),
     border_width = 1,
     frame_color  = color.new(color.gray, 40),
     frame_width  = 1)

// Helper: color from factor value
f_col(v) =>
    v > 0 ? color.lime : v < 0 ? color.red : color.gray

// Helper: arrow text from factor value  
f_arr(v) =>
    v > 0 ? "▶ BULL" : v < 0 ? "▶ BEAR" : "▶ NEUT"

if barstate.islast and i_show_factors
    // Header
    table.cell(tbl, 0, 0, "FACTOR",    bgcolor=color.new(color.navy,0),  text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 0, "SIGNAL",    bgcolor=color.new(color.navy,0),  text_color=color.white, text_size=size.small)
    table.cell(tbl, 2, 0, "VAL",       bgcolor=color.new(color.navy,0),  text_color=color.white, text_size=size.small)

    // Factor rows
    table.cell(tbl, 0, 1,  "EMA 21/55", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 1,  f_arr(f1),   text_color=f_col(f1),   text_size=size.tiny)
    table.cell(tbl, 2, 1,  str.tostring(math.round(ema21 - ema55, 1)), text_color=f_col(f1), text_size=size.tiny)

    table.cell(tbl, 0, 2,  "VWAP", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 2,  f_arr(f2),   text_color=f_col(f2),   text_size=size.tiny)
    table.cell(tbl, 2, 2,  str.tostring(math.round(close - vwap_val, 1)), text_color=f_col(f2), text_size=size.tiny)

    table.cell(tbl, 0, 3,  "RSI", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 3,  f_arr(f3),   text_color=f_col(f3),   text_size=size.tiny)
    table.cell(tbl, 2, 3,  str.tostring(math.round(rsi_val, 1)), text_color=f_col(f3), text_size=size.tiny)

    table.cell(tbl, 0, 4,  "MACD", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 4,  f_arr(f4),   text_color=f_col(f4),   text_size=size.tiny)
    table.cell(tbl, 2, 4,  str.tostring(math.round(macd_hist, 3)), text_color=f_col(f4), text_size=size.tiny)

    table.cell(tbl, 0, 5,  "SUPERTREND", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 5,  f_arr(f5),   text_color=f_col(f5),   text_size=size.tiny)
    table.cell(tbl, 2, 5,  st_dir < 0 ? "BULL" : "BEAR", text_color=f_col(f5), text_size=size.tiny)

    table.cell(tbl, 0, 6,  "ADX/DI", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 6,  f_arr(f6),   text_color=f_col(f6),   text_size=size.tiny)
    table.cell(tbl, 2, 6,  str.tostring(math.round(adx_val, 1)), text_color=f_col(f6), text_size=size.tiny)

    table.cell(tbl, 0, 7,  "RVOL", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 7,  f_arr(f7),   text_color=f_col(f7),   text_size=size.tiny)
    table.cell(tbl, 2, 7,  str.tostring(math.round(rvol, 2)) + "x", text_color=f_col(f7), text_size=size.tiny)

    table.cell(tbl, 0, 8,  "PDH/PDL", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 8,  f_arr(f8),   text_color=f_col(f8),   text_size=size.tiny)
    table.cell(tbl, 2, 8,  str.tostring(math.round(close - pdh, 1)), text_color=f_col(f8), text_size=size.tiny)

    table.cell(tbl, 0, 9,  "RSI DIV", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 9,  f_arr(f9),   text_color=f_col(f9),   text_size=size.tiny)
    table.cell(tbl, 2, 9,  f9 != 0 ? "DIV!" : "—", text_color=f_col(f9), text_size=size.tiny)

    table.cell(tbl, 0, 10, "SWEEP", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 10, f_arr(f10),  text_color=f_col(f10),  text_size=size.tiny)
    table.cell(tbl, 2, 10, f10 != 0 ? "SWEEP" : "—", text_color=f_col(f10), text_size=size.tiny)

    // JEDI combined score row — highlighted
    jedi_bg  = jedi_score >= i_min_score  ? color.new(color.lime,   20) :
               jedi_score <= -i_min_score ? color.new(color.red,    20) :
               color.new(color.gray, 40)
    jedi_dir = jedi_score >= i_min_score  ? "▲  BULL" :
               jedi_score <= -i_min_score ? "▼  BEAR" :
               "►  NEUT"

    table.cell(tbl, 0, 11, "━━━━━━━", text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 1, 11, "━━━━━━━", text_color=color.gray,  text_size=size.tiny)
    table.cell(tbl, 2, 11, "━━━━━━━", text_color=color.gray,  text_size=size.tiny)

    table.cell(tbl, 0, 12, "JEDI ORB",
         bgcolor=jedi_bg, text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 12, jedi_dir,
         bgcolor=jedi_bg,
         text_color = jedi_score >= i_min_score ? color.lime : jedi_score <= -i_min_score ? color.red : color.white,
         text_size=size.small)
    table.cell(tbl, 2, 12, str.tostring(jedi_score) + "/10",
         bgcolor=jedi_bg, text_color=color.white, text_size=size.small)

// ================================================================
// ⑩ SCORE BAND PLOTS — in a separate pane (remove overlay=true to use)
//    These are here as reference / can be moved to a new pane indicator
// ================================================================
// Uncomment these three lines if you want a score sub-pane version:
// plot(jedi_score, "JEDI Score", color=dot_col, linewidth=2)
// hline(i_min_score,  "Bull Threshold", color=color.lime,   linestyle=hline.style_dashed)
// hline(-i_min_score, "Bear Threshold", color=color.red,    linestyle=hline.style_dashed)
// hline(0,            "Neutral",        color=color.gray,   linestyle=hline.style_dotted)

// ================================================================
// END — JEDI ORB v1
// To add ONE more factor next iteration: define f_new, add to jedi_score,
// add a row to the table. That's it. Iter-opt protocol preserved.
// ================================================================
