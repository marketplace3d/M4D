//@version=6
indicator("HEATSEEKER v2 | Liquidity Thermal + Master Alpha", shorttitle="HEATSEEK v2+", overlay=true, max_lines_count=500, max_labels_count=200)

// ──────────────────────────────────────────────────
// 1. INPUTS & CONFIGURATION
// ──────────────────────────────────────────────────
grp_alpha   = "── ALPHA OVERRIDE (ITER OPT V2) ──"
i_ai_bias   = input.string("NEUTRAL", "AI Council Vote", options=["BULL", "NEUTRAL", "BEAR"], group=grp_alpha)
i_ai_conf   = input.int(80, "AI Confidence %", minval=0, maxval=100, group=grp_alpha)
i_mtf_w     = input.float(0.4, "HTF Structure Weight", minval=0, maxval=1.0, group=grp_alpha)

grp_thermal = "── LIQUIDITY THERMAL ENGINE ──"
profileType = input.string("Balanced Profile", "Profile Depth", options=["Shallow Profile", "Balanced Profile", "Deep Profile"], group=grp_thermal)
period      = profileType == "Shallow Profile" ? 100 : profileType == "Balanced Profile" ? 300 : 600
pocCol1     = input.color(color.rgb(189, 43, 43), "Upper Liquidity Color", group=grp_thermal)
pocCol2     = input.color(color.rgb(41, 180, 83), "Lower Liquidity Color", group=grp_thermal)

// ──────────────────────────────────────────────────
// 2. THERMAL MAP CALCULATIONS (BigBeluga Core)
// ──────────────────────────────────────────────────
H = ta.highest(period)
L = ta.lowest(period)
step = (H - L) / 31
volBins = array.new<float>(31, 0.)

for i = 0 to 30
    mid = L + step * i + step / 2
    for k = 0 to period - 1
        if math.abs(close[k] - mid) < step
            volBins.set(i, volBins.get(i) + volume[k])

float maxVol = volBins.max()

// ──────────────────────────────────────────────────
// 3. MASTER-TRADER ALPHA OVERRIDE ENGINE
// ──────────────────────────────────────────────────
// #1 HTF MTF Structure Confluence [cite: 1, 13]
htf1_close = request.security(syminfo.tickerid, "D", close)
htf2_close = request.security(syminfo.tickerid, "240", close)
mtf_bull = close > htf1_close and close > htf2_close
mtf_bear = close < htf1_close and close < htf2_close
float htf_alpha = mtf_bull ? 40.0 : mtf_bear ? -40.0 : 0.0

// #3 CVD Absorption & Imbalance [cite: 7, 8]
up_vol = volume * (close > open ? 1.0 : 0.5)
dn_vol = volume * (close < open ? 1.0 : 0.5)
imb_ratio = up_vol / math.max(dn_vol, 1)
float absorption_alpha = (close > open and imb_ratio < 0.8) ? -15.0 : (close < open and imb_ratio > 1.2) ? 15.0 : 0.0

// #13 Hurst Trending Multiplier [cite: 12]
hurst_est = ta.correlation(close, bar_index, 100) // Simplified Proxy
float hurst_mult = hurst_est > 0.5 ? 1.25 : 0.85

// AI Council Alpha
float ai_alpha = i_ai_bias == "BULL" ? (i_ai_conf * 0.4) : i_ai_bias == "BEAR" ? -(i_ai_conf * 0.4) : 0.0

// FINAL COMPOSITE (Capped at 90%) [cite: 4]
float raw_alpha = (htf_alpha * i_mtf_w) + absorption_alpha + ai_alpha
float composite_final = math.clamp(math.abs(raw_alpha) * hurst_mult, 0, 90)

// ──────────────────────────────────────────────────
// 4. JEDI ARROW & ATTRACTION TARGETS
// ──────────────────────────────────────────────────
bool is_bull_sig = raw_alpha > 55 and composite_final > 55
bool is_bear_sig = raw_alpha < -55 and composite_final > 55

// Dynamic Attraction: Targets glow based on Thermal Volume Bins
int splitIdx = int(math.floor((close - L) / step))
splitIdx := math.max(0, math.min(30, splitIdx))
float local_liq = volBins.get(splitIdx) / math.max(maxVol, 1)

color jedi_color = is_bull_sig ? color.new(color.lime, 100 - (composite_final)) : 
                   is_bear_sig ? color.new(color.red, 100 - (composite_final)) : color.new(color.blue, 50)

// ──────────────────────────────────────────────────
// 5. VISUALIZATION (Thermal Heat + Labels)
// ──────────────────────────────────────────────────
// Plot the Thermal Heatmap using Box objects for last bars
if barstate.islast
    for i = 0 to 30
        float ll = L + step * i
        float hh = ll + step
        float vol = volBins.get(i)
        float intensity = vol / maxVol
        color baseCol = close > (ll + step/2) ? pocCol2 : pocCol1
        
        box.new(bar_index + 5, hh, bar_index + 15, ll, 
             bgcolor=color.new(baseCol, 100 - (intensity * 80)), border_color=na)

// Jedi Arrow Label
if barstate.islast
    label.new(bar_index, high + (ta.atr(14) * 2), 
         text = (is_bull_sig ? "▲ FIRE" : is_bear_sig ? "▼ FIRE" : "▶ CALM") + "\n" + str.tostring(composite_final, "#.0") + "%",
         color = jedi_color, textcolor = color.white, style = label.style_label_down, size = size.large)

// Target Attraction Lines [cite: 58]
atr = ta.atr(14)
plot(is_bull_sig ? close + (atr * 1.5) : na, "T1 Attraction", color=color.new(color.lime, 20), style=plot.style_linebr, linewidth=2)
plot(is_bear_sig ? close - (atr * 1.5) : na, "T1 Attraction", color=color.new(color.red, 20), style=plot.style_linebr, linewidth=2)