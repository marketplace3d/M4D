// M4D Starship School — Signal Library v1.0 — regime-aware signal routing
// =========================================================================
// REFERENCE TEMPLATE ONLY. Each section is a standalone indicator function.
// Copy ONE section into a new Pine script per indicator. Do NOT paste this
// entire file as one indicator — TradingView will reject it.
//
// Regime logic runs through everything:
//   TRENDING  → trend-following signals ACTIVE  (EMA_STACK, SUPERTREND, MACD, PSAR, GOLDEN...)
//   RANGING   → mean-reversion signals ACTIVE   (RSI, STOCH, MFI, CMF...)
//   BREAKOUT  → volatility signals ACTIVE       (VOL_BO, BB_BREAK, KC_BREAK, SQZPOP, ATR_EXP...)
//   RISK-OFF  → defensive signals ACTIVE        (OBV, CMF, RSI oversold only)
//   MIXED     → reduce size, no high-conviction entries
//
// DO NOT trade SUPERTREND / EMA_STACK / MACD / PSAR in a RANGING market.
// DO NOT trade RSI_CROSS / RSI_STRONG in a TRENDING market.
// =========================================================================


// =============================================================================
// === SECTION 1: SQUEEZE DETECTOR (BB inside KC = squeeze, SQZPOP = release) ===
// =============================================================================
// Active in: BREAKOUT (on release), all regimes for context
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D Squeeze Detector", overlay=false, max_labels_count=100)

// --- Inputs ---
bb_len    = input.int(20,  "BB Length")
bb_mult   = input.float(2.0, "BB Mult")
kc_len    = input.int(20,  "KC Length")
kc_mult   = input.float(1.5, "KC Mult")

// --- Bollinger Bands ---
bb_basis  = ta.sma(close, bb_len)
bb_dev    = ta.stdev(close, bb_len)
bb_upper  = bb_basis + bb_mult * bb_dev
bb_lower  = bb_basis - bb_mult * bb_dev

// --- Keltner Channels ---
kc_basis  = ta.ema(close, kc_len)
kc_atr    = ta.atr(kc_len)
kc_upper  = kc_basis + kc_mult * kc_atr
kc_lower  = kc_basis - kc_mult * kc_atr

// --- Squeeze: BB entirely inside KC ---
in_squeeze      = bb_upper < kc_upper and bb_lower > kc_lower
squeeze_release = not in_squeeze and in_squeeze[1]  // fired on first bar OUT of squeeze

// --- Momentum histogram (LazyBear-style) ---
val = ta.linreg(close - math.avg(math.avg(ta.highest(high, kc_len), ta.lowest(low, kc_len)), bb_basis), kc_len, 0)
col = val > 0 ? (val > val[1] ? color.lime : color.green) : (val < val[1] ? color.red : color.maroon)

plot(val, "Momentum", color=col, style=plot.style_histogram, linewidth=3)
plot(0,   "Zero",     color=color.gray)

// --- Background: red in squeeze, green on pop bar ---
bgcolor(in_squeeze      ? color.new(color.red,   88) : na, title="In Squeeze")
bgcolor(squeeze_release ? color.new(color.green, 70) : na, title="Squeeze Pop")

// --- Pop label ---
if squeeze_release
    label.new(bar_index, val, "POP", style=label.style_label_up,
              color=color.green, textcolor=color.white, size=size.small)

// --- Alert ---
alertcondition(squeeze_release, "SQUEEZE RELEASED — breakout signals now ACTIVE",
               "Squeeze released on {{ticker}} — breakout signals (VOL_BO, BB_BREAK, KC_BREAK) now active")


// =============================================================================
// === SECTION 2: SUPERTREND (ATR trend direction — TRENDING regime only) ===
// =============================================================================
// Active in: TRENDING only. DISABLE when ADX < 20 (flat market).
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D SuperTrend (TRENDING only)", overlay=true)

// --- Inputs ---
st_period = input.int(10,  "ATR Period")
st_mult   = input.float(3.0, "ATR Multiplier")
adx_len   = input.int(14, "ADX Length")
adx_flat  = input.int(20, "ADX: flat threshold (disable below)")

// --- ADX (manual, no ta.adx in all versions) ---
up   = ta.change(high)
down = -ta.change(low)
plus_dm  = na(up)   ? na : (up > down and up > 0 ? up : 0)
minus_dm = na(down) ? na : (down > up and down > 0 ? down : 0)
true_range = math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))
atr14      = ta.rma(true_range, adx_len)
plus_di    = 100 * ta.rma(plus_dm,  adx_len) / atr14
minus_di   = 100 * ta.rma(minus_dm, adx_len) / atr14
dx         = 100 * math.abs(plus_di - minus_di) / (plus_di + minus_di)
adx_val    = ta.rma(dx, adx_len)

// --- SuperTrend ---
atr_st    = ta.atr(st_period)
upperband = hl2 + st_mult * atr_st
lowerband = hl2 - st_mult * atr_st
upperband := upperband < upperband[1] or close[1] > upperband[1] ? upperband : upperband[1]
lowerband := lowerband > lowerband[1] or close[1] < lowerband[1] ? lowerband : lowerband[1]

var int trend = 1
trend := close > upperband[1] ? 1 : close < lowerband[1] ? -1 : trend[1]

st_line = trend == 1 ? lowerband : upperband
dir_changed = trend != trend[1]

// --- Regime gate ---
is_trending = adx_val >= adx_flat
col_line    = is_trending ? (trend == 1 ? color.green : color.red) : color.gray

plot(st_line, "SuperTrend", color=col_line, linewidth=2)

// --- Flat market warning label ---
if not is_trending and dir_changed
    label.new(bar_index, st_line, "TREND ONLY\nDISABLED IN FLAT",
              style=label.style_label_down, color=color.orange,
              textcolor=color.white, size=size.small)

// --- Direction change signal (only when trending) ---
plotshape(dir_changed and trend == 1 and is_trending,  "Long Signal",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small)
plotshape(dir_changed and trend == -1 and is_trending, "Short Signal", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small)

alertcondition(dir_changed and is_trending,
               "SuperTrend Direction Change",
               "SuperTrend flipped on {{ticker}} — ADX={{plot_0}} — trend-regime confirmed")


// =============================================================================
// === SECTION 3: EMA STACK (8/21/34/55/89 — TRENDING + BREAKOUT regimes) ===
// =============================================================================
// Active in: TRENDING (full stack) + BREAKOUT (partial stack + momentum)
// Signal fires when 4+ of 5 EMAs aligned (not requiring full stack).
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D EMA Stack", overlay=true)

e8  = ta.ema(close, 8)
e21 = ta.ema(close, 21)
e34 = ta.ema(close, 34)
e55 = ta.ema(close, 55)
e89 = ta.ema(close, 89)

plot(e8,  "EMA8",  color=#00e5ff, linewidth=1)
plot(e21, "EMA21", color=#29b6f6, linewidth=1)
plot(e34, "EMA34", color=#1565c0, linewidth=2)
plot(e55, "EMA55", color=#7b1fa2, linewidth=2)
plot(e89, "EMA89", color=#880e4f, linewidth=2)

// --- Full bull stack: e8 > e21 > e34 > e55 > e89 ---
full_bull  = e8 > e21 and e21 > e34 and e34 > e55 and e55 > e89
full_bear  = e8 < e21 and e21 < e34 and e34 < e55 and e55 < e89

// --- Partial alignment: count bullish pairs ---
bull_pairs = (e8 > e21 ? 1 : 0) + (e21 > e34 ? 1 : 0) + (e34 > e55 ? 1 : 0) + (e55 > e89 ? 1 : 0)
bear_pairs = (e8 < e21 ? 1 : 0) + (e21 < e34 ? 1 : 0) + (e34 < e55 ? 1 : 0) + (e55 < e89 ? 1 : 0)

// --- Signal: 4+ pairs aligned ---
partial_bull = bull_pairs >= 4 and not full_bull
partial_bear = bear_pairs >= 4 and not full_bear

// --- Background ---
bgcolor(full_bull  ? color.new(color.cyan, 92)  : na, title="Full Bull Stack")
bgcolor(full_bear  ? color.new(color.pink, 92)  : na, title="Full Bear Stack")

// --- Signals ---
plotshape(ta.crossover(bull_pairs, 3),  "Stack Bull 4+", style=shape.circle, location=location.belowbar, color=color.cyan,  size=size.tiny)
plotshape(ta.crossunder(bear_pairs, 3), "Stack Bear 4+", style=shape.circle, location=location.abovebar, color=color.purple, size=size.tiny)

alertcondition(ta.crossover(bull_pairs, 3),  "EMA Stack Bull 4+", "EMA Stack 4/5 bullish on {{ticker}}")
alertcondition(ta.crossunder(bear_pairs, 3), "EMA Stack Bear 4+", "EMA Stack 4/5 bearish on {{ticker}}")


// =============================================================================
// === SECTION 4: RSI MEAN REVERSION (RANGING regime only) ===
// =============================================================================
// Active in: RANGING + RISK-OFF. DO NOT use when ADX > 25 (trending market).
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D RSI Mean Reversion (RANGING only)", overlay=false)

rsi_len  = input.int(14, "RSI Length")
adx_len  = input.int(14, "ADX Length")
adx_warn = input.int(25, "ADX: trend warning threshold (DO NOT USE above)")
ob_level = input.int(70, "Overbought")
os_level = input.int(30, "Oversold")

rsi_val = ta.rsi(close, rsi_len)

// --- ADX ---
up   = ta.change(high)
down = -ta.change(low)
plus_dm  = na(up)   ? na : (up > down and up > 0 ? up : 0)
minus_dm = na(down) ? na : (down > up and down > 0 ? down : 0)
true_range = math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))
atr14      = ta.rma(true_range, adx_len)
plus_di    = 100 * ta.rma(plus_dm,  adx_len) / atr14
minus_di   = 100 * ta.rma(minus_dm, adx_len) / atr14
dx         = 100 * math.abs(plus_di - minus_di) / (plus_di + minus_di)
adx_val    = ta.rma(dx, adx_len)

is_ranging  = adx_val < adx_warn
is_trending = adx_val >= adx_warn

plot(rsi_val,  "RSI",    color=is_ranging ? color.blue : color.gray, linewidth=2)
hline(ob_level, "OB",   color=color.red,   linestyle=hline.style_dashed)
hline(50,       "Mid",  color=color.gray,  linestyle=hline.style_dotted)
hline(os_level, "OS",   color=color.green, linestyle=hline.style_dashed)

// --- Signals (ranging only) ---
rsi_buy  = ta.crossover(rsi_val,  os_level) and is_ranging
rsi_sell = ta.crossunder(rsi_val, ob_level) and is_ranging

plotshape(rsi_buy,  "RSI Buy",  style=shape.triangleup,   location=location.bottom, color=color.green, size=size.small)
plotshape(rsi_sell, "RSI Sell", style=shape.triangledown, location=location.top,    color=color.red,   size=size.small)

// --- Trend warning label ---
if is_trending and (ta.crossover(rsi_val, os_level) or ta.crossunder(rsi_val, ob_level))
    label.new(bar_index, rsi_val, "RANGING SIGNAL\nDO NOT USE IN TREND",
              style=label.style_label_right, color=color.orange,
              textcolor=color.white, size=size.small)

bgcolor(is_trending ? color.new(color.orange, 90) : na, title="Trending (RSI inactive)")

alertcondition(rsi_buy,  "RSI Mean Reversion Buy",  "RSI crossed above 30 on {{ticker}} — RANGING confirmed (ADX={{plot_0}})")
alertcondition(rsi_sell, "RSI Mean Reversion Sell", "RSI crossed below 70 on {{ticker}} — RANGING confirmed")


// =============================================================================
// === SECTION 5: REGIME DETECTOR (meta-indicator — current regime + active signals) ===
// =============================================================================
// This is the MASTER filter. Run this on every chart to know which signals
// are ACTIVE. Pin to bottom panel or as a separate window.
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D Regime Detector", overlay=false, max_bars_back=500)

adx_len      = input.int(14,  "ADX Length")
adx_trend    = input.int(25,  "ADX Trending threshold")
adx_flat     = input.int(20,  "ADX Flat threshold")
atr_len      = input.int(20,  "ATR Length for breakout detection")
atr_mult_bo  = input.float(1.5, "ATR multiplier for breakout")

// --- ADX ---
up   = ta.change(high)
down = -ta.change(low)
plus_dm  = na(up)   ? na : (up > down and up > 0 ? up : 0)
minus_dm = na(down) ? na : (down > up and down > 0 ? down : 0)
true_range = math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))
atr14      = ta.rma(true_range, adx_len)
plus_di    = 100 * ta.rma(plus_dm,  adx_len) / atr14
minus_di   = 100 * ta.rma(minus_dm, adx_len) / atr14
dx         = 100 * math.abs(plus_di - minus_di) / (plus_di + minus_di)
adx_val    = ta.rma(dx, adx_len)

// --- ATR expansion for breakout ---
atr_now  = ta.atr(1)
atr_avg  = ta.sma(atr_now, atr_len)
atr_exp  = atr_now > atr_mult_bo * atr_avg

// --- Regime classification ---
is_trending = adx_val >= adx_trend
is_ranging  = adx_val < adx_flat and not atr_exp
is_breakout = atr_exp
// Simplified RISK-OFF: heavy ATR expansion + bearish momentum
mom         = ta.ema(close, 12) - ta.ema(close, 26)
is_risk_off = atr_exp and mom < 0 and adx_val > adx_trend

regime_val = is_risk_off ? -2 : is_trending ? 2 : is_breakout ? 3 : is_ranging ? 0 : 1

// --- Background by regime ---
bgcolor(is_trending and not is_risk_off ? color.new(color.blue,   88) : na, title="TRENDING")
bgcolor(is_ranging                       ? color.new(color.yellow, 88) : na, title="RANGING")
bgcolor(is_breakout and not is_trending  ? color.new(color.green,  88) : na, title="BREAKOUT")
bgcolor(is_risk_off                      ? color.new(color.red,    85) : na, title="RISK-OFF")

plot(adx_val,    "ADX",     color=color.white,  linewidth=2)
plot(plus_di,    "+DI",     color=color.green,  linewidth=1)
plot(minus_di,   "-DI",     color=color.red,    linewidth=1)
hline(adx_trend, "Trend",  color=color.blue,   linestyle=hline.style_dotted)
hline(adx_flat,  "Flat",   color=color.yellow, linestyle=hline.style_dotted)

// --- Table: current regime + active signals ---
var table reg_table = table.new(position.top_right, 2, 8,
                                 bgcolor=color.new(color.black, 70),
                                 border_width=1)
if barstate.islast
    regime_str = is_risk_off ? "RISK-OFF" : is_trending ? "TRENDING" : is_breakout ? "BREAKOUT" : is_ranging ? "RANGING" : "MIXED"
    reg_col    = is_risk_off ? color.red : is_trending ? color.blue : is_breakout ? color.green : is_ranging ? color.yellow : color.gray

    table.cell(reg_table, 0, 0, "REGIME",       text_color=color.white, bgcolor=color.new(color.black, 50))
    table.cell(reg_table, 1, 0, regime_str,      text_color=color.white, bgcolor=reg_col)
    table.cell(reg_table, 0, 1, "ADX",           text_color=color.white)
    table.cell(reg_table, 1, 1, str.tostring(math.round(adx_val, 1)), text_color=color.white)
    table.cell(reg_table, 0, 2, "ACTIVE",        text_color=color.gray)
    table.cell(reg_table, 1, 2, is_trending ? "SUPERTREND EMA MACD PSAR GOLDEN" :
                                is_breakout ? "VOL_BO BB_BREAK KC_BREAK SQZPOP ATR_EXP" :
                                is_ranging  ? "RSI STOCH MFI CMF" : "OBV CMF RSI-OS",
               text_color=color.lime, text_size=size.tiny)
    table.cell(reg_table, 0, 3, "BLOCKED",       text_color=color.gray)
    table.cell(reg_table, 1, 3, is_ranging ? "SUPERTREND EMA_STACK MACD PSAR" :
                                is_trending ? "RSI_CROSS RSI_STRONG STOCH" : "N/A",
               text_color=color.red, text_size=size.tiny)


// =============================================================================
// === SECTION 6: JEDI MASTER COMPOSITE SCORE ===
// =============================================================================
// Manual input version — user enters vote counts from the M4D dashboard.
// Jedi = A_net*0.35 + B_net*0.40 + C_net*0.25
// GO_LONG threshold: +8  |  GO_SHORT threshold: -8
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D JEDI Master Score", overlay=false)

// --- Inputs: vote counts from M4D Council dashboard ---
A_long  = input.int(0, "Bank A: Long votes",  minval=0, maxval=9)
A_short = input.int(0, "Bank A: Short votes", minval=0, maxval=9)
B_long  = input.int(0, "Bank B: Long votes",  minval=0, maxval=9)
B_short = input.int(0, "Bank B: Short votes", minval=0, maxval=9)
C_long  = input.int(0, "Bank C: Long votes",  minval=0, maxval=9)
C_short = input.int(0, "Bank C: Short votes", minval=0, maxval=9)

long_thresh  = input.int(8,  "Go Long threshold")
short_thresh = input.int(-8, "Go Short threshold")

// --- JEDI formula ---
A_net    = A_long - A_short
B_net    = B_long - B_short
C_net    = C_long - C_short
jedi_raw = A_net * 0.35 + B_net * 0.40 + C_net * 0.25

// --- Display as constant horizontal bands (since inputs are manual) ---
jedi_line = line.new(bar_index - 100, jedi_raw, bar_index, jedi_raw,
                     color=jedi_raw >= long_thresh  ? color.lime :
                           jedi_raw <= short_thresh ? color.red : color.white,
                     width=3, extend=extend.right)

// --- Histogram plot for visual ---
plot(jedi_raw,     "JEDI Score", color=jedi_raw > 0 ? color.lime : color.red,
     style=plot.style_histogram, linewidth=4)
hline(long_thresh,  "GO LONG",  color=color.green, linestyle=hline.style_solid)
hline(short_thresh, "GO SHORT", color=color.red,   linestyle=hline.style_solid)
hline(0,            "Zero",     color=color.gray,  linestyle=hline.style_dotted)

// --- Conviction labels ---
if barstate.islast
    if jedi_raw >= long_thresh
        label.new(bar_index, jedi_raw, "GO LONG\nJEDI=" + str.tostring(math.round(jedi_raw, 1)),
                  style=label.style_label_left, color=color.green, textcolor=color.white)
    else if jedi_raw <= short_thresh
        label.new(bar_index, jedi_raw, "GO SHORT\nJEDI=" + str.tostring(math.round(jedi_raw, 1)),
                  style=label.style_label_left, color=color.red, textcolor=color.white)
    else
        label.new(bar_index, jedi_raw, "NEUTRAL\nJEDI=" + str.tostring(math.round(jedi_raw, 1)),
                  style=label.style_label_left, color=color.gray, textcolor=color.white)


// =============================================================================
// === SECTION 7: TRADE QUALITY GATE (SEAL Team 6 filter) ===
// =============================================================================
// ALL conditions must be GREEN to enter. Any red = BLOCKED.
// Conditions: NOT in squeeze + NOT in cloud + RVOL > 0.7 + ATR not flat + NOT in PDH/PDL middle
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D Trade Quality Gate (SEAL Team 6)", overlay=false, max_bars_back=500)

// --- Inputs ---
rvol_min    = input.float(0.7, "Min RVOL (relative volume)")
rvol_len    = input.int(20,    "RVOL lookback")
atr_flat_th = input.float(0.6, "ATR flat threshold (pct of 20-bar avg)")
bb_len      = input.int(20,    "BB Length")
bb_mult     = input.float(2.0, "BB Mult")
kc_len      = input.int(20,    "KC Length")
kc_mult     = input.float(1.5, "KC Mult")

// --- Squeeze check ---
bb_dev    = ta.stdev(close, bb_len)
bb_upper  = ta.sma(close, bb_len) + bb_mult * bb_dev
bb_lower  = ta.sma(close, bb_len) - bb_mult * bb_dev
kc_atr    = ta.atr(kc_len)
kc_basis  = ta.ema(close, kc_len)
kc_upper  = kc_basis + kc_mult * kc_atr
kc_lower  = kc_basis - kc_mult * kc_atr
in_squeeze = bb_upper < kc_upper and bb_lower > kc_lower

// --- RVOL ---
vol_avg = ta.sma(volume, rvol_len)
rvol    = vol_avg > 0 ? volume / vol_avg : 0.0
rvol_ok = rvol >= rvol_min

// --- ATR not flat ---
atr_now = ta.atr(1)
atr_avg = ta.sma(atr_now, 20)
atr_ok  = atr_now >= atr_flat_th * atr_avg

// --- Ichimoku cloud (simplified: price above/below span) ---
conv  = (ta.highest(high, 9)  + ta.lowest(low, 9))  / 2
base  = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
span_a = (conv + base) / 2
span_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
cloud_top    = math.max(span_a, span_b)
cloud_bottom = math.min(span_a, span_b)
not_in_cloud = close > cloud_top or close < cloud_bottom

// --- PDH/PDL middle zone ---
pdh = ta.highest(high[1], 1)   // previous day high (approx from last bar)
pdl = ta.lowest(low[1], 1)
pdh_d = request.security(syminfo.tickerid, "D", high[1])
pdl_d = request.security(syminfo.tickerid, "D", low[1])
mid_zone_top    = pdl_d + 0.6 * (pdh_d - pdl_d)
mid_zone_bottom = pdl_d + 0.4 * (pdh_d - pdl_d)
not_in_pdh_mid  = close < mid_zone_bottom or close > mid_zone_top

// --- Gate: ALL must be true ---
gate_clear = not in_squeeze and not_in_cloud and rvol_ok and atr_ok and not_in_pdh_mid

// --- Plot: 0 = blocked, 1 = clear ---
plot(gate_clear ? 1 : 0, "Gate", style=plot.style_area,
     color=gate_clear ? color.new(color.green, 60) : color.new(color.red, 60),
     linewidth=1)
hline(1, "Clear",   color=color.green, linestyle=hline.style_dotted)
hline(0, "Blocked", color=color.red,   linestyle=hline.style_dotted)

// --- Status labels (show which condition is blocking) ---
if barstate.islast and not gate_clear
    reasons = ""
    if in_squeeze
        reasons := reasons + "SQUEEZE "
    if not not_in_cloud
        reasons := reasons + "IN_CLOUD "
    if not rvol_ok
        reasons := reasons + "LOW_RVOL(" + str.tostring(math.round(rvol, 2)) + ") "
    if not atr_ok
        reasons := reasons + "FLAT_ATR "
    if not not_in_pdh_mid
        reasons := reasons + "PDH/PDL_MID "
    label.new(bar_index, 0, "BLOCKED: " + reasons,
              style=label.style_label_up, color=color.red,
              textcolor=color.white, size=size.small)

alertcondition(gate_clear and not gate_clear[1], "Gate OPENED — CLEAR TO TRADE",
               "Trade quality gate cleared on {{ticker}} — all SEAL conditions met")
alertcondition(not gate_clear and gate_clear[1], "Gate BLOCKED",
               "Trade quality gate BLOCKED on {{ticker}} — check conditions")


// =============================================================================
// === SECTION 8: PDH/PDL MIDDLE ZONE FILTER ===
// =============================================================================
// Plots previous-day high/low. Shades middle 40-60% zone in orange.
// DO NOT TRADE inside the middle zone — price is in the value area.
// Pine Script v5 — copy this block into its own indicator script

//@version=5
indicator("M4D PDH/PDL Middle Zone", overlay=true)

mid_pct_low  = input.float(0.40, "Middle zone bottom (pct of PDH-PDL range)", minval=0.1, maxval=0.9)
mid_pct_high = input.float(0.60, "Middle zone top    (pct of PDH-PDL range)", minval=0.1, maxval=0.9)
show_zone    = input.bool(true, "Show middle zone fill")

// --- Previous day OHLC via D timeframe request ---
pdh = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)

mid_top    = pdl + mid_pct_high * (pdh - pdl)
mid_bottom = pdl + mid_pct_low  * (pdh - pdl)

// --- Plot PDH / PDL as horizontal lines ---
plot(pdh,        "PDH",        color=color.red,           linewidth=1, style=plot.style_stepline)
plot(pdl,        "PDL",        color=color.green,         linewidth=1, style=plot.style_stepline)
plot(mid_top,    "Mid Zone H", color=color.new(color.orange, 40), linewidth=1, style=plot.style_stepline)
plot(mid_bottom, "Mid Zone L", color=color.new(color.orange, 40), linewidth=1, style=plot.style_stepline)

// --- Shade middle zone ---
mid_top_p    = plot(show_zone ? mid_top    : na, display=display.none)
mid_bottom_p = plot(show_zone ? mid_bottom : na, display=display.none)
fill(mid_top_p, mid_bottom_p, color=color.new(color.orange, 82), title="PDH/PDL Middle (DO NOT TRADE)")

// --- In-zone detection ---
in_mid_zone = close >= mid_bottom and close <= mid_top

bgcolor(in_mid_zone ? color.new(color.orange, 88) : na, title="Price in Middle Zone")

// --- Entry/exit zone alerts ---
entering_zone = in_mid_zone and not in_mid_zone[1]
leaving_zone  = not in_mid_zone and in_mid_zone[1]

if entering_zone
    label.new(bar_index, close, "ENTERED\nMID ZONE\nDO NOT TRADE",
              style=label.style_label_left, color=color.orange,
              textcolor=color.white, size=size.small)
if leaving_zone
    label.new(bar_index, close, "LEFT\nMID ZONE\nOK to trade",
              style=label.style_label_left, color=color.gray,
              textcolor=color.white, size=size.tiny)

alertcondition(entering_zone, "Price Entering PDH/PDL Middle Zone",
               "{{ticker}} entered PDH/PDL middle zone — avoid entries here")
alertcondition(leaving_zone,  "Price Leaving PDH/PDL Middle Zone",
               "{{ticker}} left PDH/PDL middle zone — entries permitted again")
