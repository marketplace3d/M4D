# ══════════════════════════════════════════════════════════════════════════════
# M4D MONO-REPO — .gitignore
# Rule: source + config + lock files only. Everything generated stays local.
# ══════════════════════════════════════════════════════════════════════════════


# ── SECRETS ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.env.local
.env copy.local
**/secrets.json
**/credentials.json
*.pem
*.key


# ── OS NOISE ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
**/.DS_Store
._*
**/.DS_Store
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ── EDITOR ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~


# ── CLAUDE AI SESSION DATA ────────────────────────────────────────────────────
.claude/


# ── LARGE REFERENCE / ARCHIVE FOLDERS ────────────────────────────────────────
M4D-REF-TEMP/
AGENT1/
O/

# Legacy tracked versions — to untrack: git rm -r --cached <dir> && git commit
# M1D/   W3D/   W4D/   pwa/   site/   MRT/


# ── RUST BUILD ARTIFACTS ──────────────────────────────────────────────────────
target/
**/target/
**/*.rs.bk
**/*.pdb


# ── NODE / VITE — ALL FRONTENDS ───────────────────────────────────────────────
# Generic (covers any new frontend dir automatically)
**/node_modules/
**/dist/
**/.vite/
**/.cache/
**/.svelte-kit/
**/.parcel-cache/
**/.next/
*.tsbuildinfo
**/.npm/

# m5d explicit (63K node_modules — critical to exclude)
m5d/node_modules/
m5d/dist/
m5d/.vite/

# M4D explicit
M4D/node_modules/
M4D/dist/
M4D/build/
M4D/.vite/

# Legacy frontends
site/node_modules/
site/dist/
pwa/node_modules/
pwa/dist/
pwa/build/
W3D/node_modules/
W3D/dist/
W4D/site/node_modules/
W4D/dist/


# ── PYTHON ────────────────────────────────────────────────────────────────────
**/.venv/
**/venv/
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
*.egg-info/
ds/staticfiles/
ds/media/
m4d-ds/staticfiles/
m4d-ds/media/
local_settings.py


# ── DATABASES ─────────────────────────────────────────────────────────────────
**/*.db
**/*.db-shm
**/*.db-wal
**/*.sqlite
**/*.sqlite3


# ── DS RUNTIME DATA (regenerated — do not commit live output) ─────────────────
ds/data/futures_walkforward_report.json
ds/data/holdout_report.json
ds/data/iopt_euphoria.json
ds/data/iopt_max.json
ds/data/pulse_latest.json
ds/data/pulse_history.json
ds/data/maxcogviz_history.json
ds/data/xsocial_latest.json

engine/data/
!engine/data/.gitkeep
m4d-engine/out/
!m4d-engine/out/.gitkeep
m4d-ds/data/


# ── LARGE BINARY DOCS ─────────────────────────────────────────────────────────
APP-DOC/**/*.rtf
APP-DOC/**/*.odt
APP-DOC/**/*.docx
APP-DOC/**/*.pdf
APP-DOC/RENTECH/*.html


# ── LOGS + TEMP ───────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
coverage/
.nyc_output/
*.tmp
*.bak
*.orig
*.rej
.cache/
tmp/
temp/
go\ copy.sh


