# Polygon key — either name is fine (same value)
POLYGON_IO_KEY=
# POLYGON_API_KEY=

# Optional static deploy (key exposed in JS bundle):
# VITE_POLYGON_IO_KEY=
# VITE_POLYGON_API_KEY=

# Mock “sentiment up” for council vote (0–1). Wire X/News API later.
# VITE_MOCK_SENTIMENT=0.72

# Bar cache (Polygon + Binance) — memory + localStorage; higher = fewer API calls (ms, min 30000).
# VITE_BARS_CACHE_TTL_MS=900000
# Overrides when VITE_BARS_CACHE_TTL_MS unset: daily vs minute Polygon aggs
# VITE_BARS_CACHE_TTL_DAY_MS=3600000
# VITE_BARS_CACHE_TTL_MINUTE_MS=480000
